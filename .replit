modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN = "nexora-f50db.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID = "nexora-f50db"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET = "nexora-f50db.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "476639252277"
NEXT_PUBLIC_FIREBASE_DATABASE_URL = "https://nexora-f50db-default-rtdb.firebaseio.com"
